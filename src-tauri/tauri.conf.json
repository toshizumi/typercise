{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Typercise",
  "version": "0.2.0",
  "identifier": "jp.garage-standard.keycount",
  "build": {
    "beforeDevCommand": "cd .. && trunk serve",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd .. && trunk build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "popover",
        "title": "Typercise",
        "url": "index.html",
        "width": 340,
        "height": 520,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "visible": false,
        "focus": true,
        "shadow": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "entitlements.plist",
      "signingIdentity": null
    }
  }
}
